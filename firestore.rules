rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if the current user is an admin.
    // An admin is either:
    // 1. The hardcoded super admin email (mahaboobbasha140724@gmail.com)
    // 2. A user with 'admin' role in their user document database record
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'mahaboobbasha140724@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // 1. A user can read their own profile document
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // 2. A user can create their own profile document, but must set role to 'user'
      // (unless they are the super admin, who can set it to 'admin')
      allow create: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role == 'user' || 
        request.auth.token.email == 'mahaboobbasha140724@gmail.com'
      );
      
      // 3. A user can update their own profile, but CANNOT modify the 'role' field
      allow update: if isAuthenticated() && request.auth.uid == userId && (
        request.resource.data.role == resource.data.role
      );
      
      // 4. Admins have full access to manage roles and list users
      allow read, list, write: if isAdmin();
      
      // Paper Trading Subcollections
      match /portfolio/{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /positions/{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
      match /orders/{document=**} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }
    
    // Deny read/write access to all other paths by default unless authenticated
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
